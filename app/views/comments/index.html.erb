<% content_for :title, "Comments with ActionText" %>

<div class="container mx-auto px-4 py-8 max-w-4xl">
  <h1 class="text-3xl font-bold text-gray-900 mb-8">Comments with ActionText</h1>
  
  <!-- Flash Messages -->
  <% if notice %>
    <div class="bg-green-100 border border-green-400 text-green-700 px-4 py-3 rounded mb-4">
      <%= notice %>
    </div>
  <% end %>
  
  <!-- New Comment Form -->
  <div class="bg-white shadow rounded-lg p-6 mb-8">
    <h2 class="text-xl font-semibold text-gray-800 mb-4">Add a New Comment</h2>
    
    <%= form_with(model: @comment, local: true, class: "space-y-4") do |form| %>
      <% if @comment.errors.any? %>
        <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded">
          <h4 class="font-bold">Please fix the following errors:</h4>
          <ul class="list-disc list-inside">
            <% @comment.errors.full_messages.each do |message| %>
              <li><%= message %></li>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div>
        <%= form.label :author, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.text_field :author, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-blue-500", placeholder: "Your name" %>
      </div>

      <div>
        <%= form.label :content, "Comment", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= form.rich_text_area :content, class: "w-full", placeholder: "Write your comment here..." %>
      </div>

      <div>
        <%= form.submit "Post Comment", class: "bg-blue-500 hover:bg-blue-700 text-white font-bold py-2 px-4 rounded focus:outline-none focus:shadow-outline" %>
      </div>
    <% end %>
  </div>

  <!-- Comments List -->
  <div class="space-y-6">
    <h2 class="text-2xl font-semibold text-gray-800">Comments (<%= @comments.count %>)</h2>
    
    <% if @comments.any? %>
      <% @comments.each do |comment| %>
        <div class="bg-white shadow rounded-lg p-6">
          <div class="flex items-center justify-between mb-4">
            <h3 class="text-lg font-semibold text-gray-800"><%= comment.author %></h3>
            <span class="text-sm text-gray-500"><%= comment.created_at.strftime("%B %d, %Y at %I:%M %p") %></span>
          </div>
          
          <div class="prose max-w-none">
            <%= comment.content %>
          </div>
        </div>
      <% end %>
    <% else %>
      <div class="text-center py-8">
        <p class="text-gray-500 text-lg">No comments yet. Be the first to comment!</p>
      </div>
    <% end %>
  </div>
</div>
